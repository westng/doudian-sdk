# 抖店SDK配置文件示例
# 复制此文件为 .env 并填入真实配置
# 仅用于本仓库测试，不是 SDK 正常接入方式

# 应用凭证（必需）
DOUDIAN_APP_KEY=your_app_key
DOUDIAN_APP_SECRET=your_app_secret

# 店铺信息（必需）
DOUDIAN_SHOP_ID=your_shop_id

# 访问令牌（可选，已拿到token时可直接填写，测试会优先使用）
DOUDIAN_TOKEN=your_access_token

# 刷新令牌（可选，用于令牌刷新测试）
DOUDIAN_REFRESH_TOKEN=your_refresh_token

# 访问令牌类型（可选，默认为2）
# 2 = 店铺ID模式（推荐）
# 1 = 授权码模式
DOUDIAN_ACCESS_TOKEN_SHOP_ID=2

# 集成测试开关（可选，默认为false）
# true = 启用集成测试（需要真实API凭证和IP白名单）
# false = 跳过集成测试
DOUDIAN_INTEGRATION_TEST=true

# 商品相关集成测试默认使用 tests/fixtures/ 下的 JSON 测试数据
# 如需调整 Step3 / Step4 请求参数，请直接修改对应 fixture 文件

# 注意事项：
# 1. 请确保服务器IP已添加到抖店开放平台的IP白名单
# 2. 登录地址：https://op.jinritemai.com/ → 应用管理 → IP白名单
# 3. 不要将此文件提交到版本控制系统
